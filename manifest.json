{
  "manifest_version": 3,
  "name": "Instant Whiteboard",
  "version": "0.1.0",
  "description": "A slick, minimal whiteboard one click or hotkey away.",
  "minimum_chrome_version": "114",
  "action": {
    "default_title": "Open Instant Whiteboard",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "background": {
    "service_worker": "src/background/background.ts",
    "type": "module"
  },
  "commands": {
    "open-whiteboard": {
      "suggested_key": {
        "default": "Ctrl+Shift+W",
        "mac": "Command+Shift+W"
      },
      "description": "Open Instant Whiteboard"
    }
  },
  "permissions": ["storage", "tabs", "unlimitedStorage"]
}
